@model Inventario.MODEL.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<h1 class="mb-4">Editar Producto</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post" novalidate>
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly">
                <div class="alert alert-danger" role="alert">
                    <strong>Por favor corrige los siguientes errores:</strong>
                    <ul>
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej. Laptop HP" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Categoria" class="form-label"></label>
                    <input asp-for="Categoria" class="form-control" placeholder="Ej. Electrónica" />
                    <span asp-validation-for="Categoria" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Precio" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">₡</span>
                        <input asp-for="Precio" class="form-control" type="number" step="0.01" min="1" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Precio" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3 d-flex align-items-center">
                    <div class="form-check mt-2">
                        <input asp-for="Activo" class="form-check-input" />
                        <label asp-for="Activo" class="form-check-label ms-2"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
