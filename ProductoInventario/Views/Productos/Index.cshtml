@model IEnumerable<Inventario.MODEL.Producto>

@{
    ViewData["Title"] = "Productos";
    var productos = Model?.ToList() ?? new List<Inventario.MODEL.Producto>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Catálogo de Productos <span class="badge bg-secondary ms-2">@productos.Count</span></h1>
    <div>
        <a class="btn btn-primary btn-sm" asp-action="Create">Agregar Producto</a>
    </div>
</div>

@if (!productos.Any())
{
    <div class="card">
        <div class="card-body text-center">
            <h5 class="card-title">No hay productos registrados.</h5>
            <p class="card-text">Agrega tu primer producto al catálogo.</p>
            <a class="btn btn-primary" asp-action="Create">Agregar Producto</a>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Categoría</th>
                    <th>Fecha de Ingreso</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in productos)
            {
                <tr>
                    <td class="fw-semibold">@item.Nombre</td>
                    <td>@String.Format("{0:C0}", item.Precio)</td>
                    <td>@item.Categoria</td>
                    <td>@item.FechaIngreso.ToString("g")</td>
                    <td>
                        @if (item.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@* Search removed as requested *@
